{
  "name": "flowscript-core",
  "version": "1.1.2",
  "description": "Decision intelligence for AI agents. Typed semantic queries over structured reasoning.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "tool-integrity.json",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vercel": {
      "types": "./dist/vercel.d.ts",
      "require": "./dist/vercel.js",
      "default": "./dist/vercel.js"
    }
  },
  "bin": {
    "flowscript": "./bin/flowscript",
    "flowscript-mcp": "./bin/flowscript-mcp"
  },
  "scripts": {
    "build": "tsc && cp src/grammar.ohm dist/grammar.ohm",
    "test": "NODE_OPTIONS='--max-old-space-size=2048' jest",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=2048' jest --watch",
    "clean": "rm -rf dist",
    "generate-manifest": "node dist/mcp-server.js --generate-manifest",
    "prepublishOnly": "npm run build && npm run generate-manifest && npm test"
  },
  "keywords": [
    "flowscript",
    "decision-intelligence",
    "agent-memory",
    "semantic-queries",
    "ai-agents",
    "query-engine",
    "cognitive-architecture",
    "llm-memory",
    "agent-tools",
    "reasoning",
    "explainability",
    "audit-trail"
  ],
  "author": "Phillip Clapham <me@phillipclapham.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phillipclapham/flowscript.git"
  },
  "homepage": "https://flowscript.org",
  "bugs": {
    "url": "https://github.com/phillipclapham/flowscript/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.12.0",
    "commander": "^11.0.0",
    "ohm-js": "^17.2.1"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  }
}