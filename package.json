{
  "name": "flowscript",
  "version": "1.0.0",
  "description": "Decision intelligence for AI agents. Typed semantic queries over structured reasoning.",
  "main": "dist/index.js",
  "bin": {
    "flowscript": "./bin/flowscript"
  },
  "scripts": {
    "build": "tsc && cp src/grammar.ohm dist/grammar.ohm",
    "test": "NODE_OPTIONS='--max-old-space-size=2048' jest",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=2048' jest --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "flowscript",
    "decision-intelligence",
    "agent-memory",
    "semantic-queries",
    "ai-agents",
    "query-engine",
    "cognitive-architecture"
  ],
  "author": "Phillip Clapham",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "commander": "^11.0.0",
    "ohm-js": "^17.2.1"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  }
}
